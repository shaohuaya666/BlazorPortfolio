@page "/"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@using System.Threading
@using BlazorPortfolio.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>个人简历（Blazor Server）</PageTitle>

<style>
    html {
        scroll-behavior: smooth;
    }

    /* 为每个 section 添加滚动偏移，补偿固定导航栏高度 */
    section[id] {
        scroll-margin-top: 100px;
    }
</style>

<!-- Header sticky nav -->
<nav class="bg-[#051424]/80 backdrop-blur-xl border-b border-slate-800/40 sticky top-0 z-50 transition-all duration-300">
    <div class="flex justify-between items-center w-full px-6 max-w-7xl mx-auto h-20">
        <!-- Logo -->
        <div class="font-mono text-lg font-bold tracking-tighter text-[#bec6e0] cursor-pointer hover:text-white transition-colors flex items-center gap-2">
            <span class="w-2.5 h-2.5 bg-[#4fdbc8] rounded-full animate-pulse"></span>
           (Blazor Server)
        </div>

        <!-- Links -->
        <div class="hidden md:flex items-center gap-8">
            <a href="#experience" class="font-mono text-xs uppercase tracking-widest text-[#c6c6cd] hover:text-[#bec6e0] transition-colors">
                工作经历
            </a>
            <a href="#projects" class="font-mono text-xs uppercase tracking-widest text-[#c6c6cd] hover:text-[#bec6e0] transition-colors">
                项目经历
            </a>
            <a href="#skills" class="font-mono text-xs uppercase tracking-widest text-[#c6c6cd] hover:text-[#bec6e0] transition-colors">
                技术栈
            </a>
            <a href="#contact" class="font-mono text-xs uppercase tracking-widest text-[#c6c6cd] hover:text-[#bec6e0] transition-colors">
                联系方式
            </a>
        </div>

        <!-- Download CTA -->
        <div>
            @* <button @onclick="ToggleResumeModal"
                class="bg-[#bec6e0] text-[#283044] hover:bg-white px-5 py-2.5 rounded-lg font-mono font-bold text-xs uppercase tracking-wider transition-all duration-150 active:scale-95 flex items-center gap-2 cursor-pointer">
                <span class="material-symbols-outlined text-sm">download</span>
                Download CV
            </button> *@
        </div>
    </div>
</nav>

<!-- Hero Section -->
<header class="relative overflow-hidden min-h-[600px] flex items-center justify-center py-16">
    <div class="absolute inset-0 bg-[#051424]">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[radial-gradient(#1e293b_1.5px,transparent_1.5px)] [background-size:24px_24px] opacity-15"></div>
    </div>

    <div class="relative z-10 max-w-7xl px-6 text-center space-y-6">
        <div class="flex flex-wrap justify-center gap-3">
            <div class="inline-flex items-center gap-2 py-1 px-3 bg-[#4fdbc8]/10 border border-[#4fdbc8]/20 text-[#4fdbc8] font-mono text-xs rounded-full">
                <span class="w-1.5 h-1.5 bg-[#4fdbc8] rounded-full animate-ping"></span>
                .NET Core 8 Blazor Server Active
            </div>

            @if (hubConnection?.State == HubConnectionState.Connected)
            {
                <div class="inline-flex items-center gap-2 py-1 px-3 bg-green-500/10 border border-green-500/20 text-green-400 font-mono text-xs rounded-full">
                    <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
                    SignalR 实时通信已连接
                </div>
            }
            else if (hubConnection?.State == HubConnectionState.Connecting)
            {
                <div class="inline-flex items-center gap-2 py-1 px-3 bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 font-mono text-xs rounded-full">
                    <span class="w-1.5 h-1.5 bg-yellow-400 rounded-full animate-bounce"></span>
                    SignalR 连接中...
                </div>
            }
            else
            {
                <div class="inline-flex items-center gap-2 py-1 px-3 bg-red-500/10 border border-red-500/20 text-red-400 font-mono text-xs rounded-full">
                    <span class="w-1.5 h-1.5 bg-red-400 rounded-full"></span>
                    SignalR 未连接
                </div>
            }
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-tight tracking-tight text-white max-w-5xl mx-auto">
            全栈开发工程师 <br />
            <span class="bg-gradient-to-r from-[#bec6e0] via-[#adc6ff] to-[#4fdbc8] bg-clip-text text-transparent">
                专注数字化系统研发
            </span>
        </h1>

        <p class="max-w-3xl mx-auto text-sm sm:text-base md:text-lg text-[#c6c6cd] leading-relaxed">
            熟悉企业级高并发、复杂IoT集成、高可用架构设计，可交付可执行的后端原型代码，保证演示效果与设计文档一致。
        </p>

        <div class="flex flex-wrap gap-4 justify-center pt-2">
            <a href="#projects"
                class="bg-[#adc6ff] text-[#002e6a] hover:bg-white px-8 py-3.5 rounded-lg font-mono font-bold text-xs uppercase tracking-widest transition-all duration-150 active:scale-95 shadow-lg shadow-blue-500/10 flex items-center gap-1.5">
                查看核心项目 Projects
            </a>
            <a href="#contact"
                class="border border-[#909097]/40 text-[#d4e4fa] hover:bg-slate-800/40 px-8 py-3.5 rounded-lg font-mono font-bold text-xs uppercase tracking-widest transition-all duration-150 active:scale-95 flex items-center gap-1.5">
                联系合作 Handshake
            </a>
        </div>

        <div class="pt-8 max-w-2xl mx-auto">
            <div class="text-[10px] text-slate-500 font-mono flex items-center justify-center gap-1.5">
                <span class="material-symbols-outlined text-[12px] text-[#3b82f6]">cpu</span>
                BLAZOR SIGNALR TELEMETRY: @telemetryHz HZ • HIGHLY INTERACTIVE SIGNAL STATE
            </div>
        </div>
    </div>
</header>

<main class="max-w-7xl mx-auto px-6 pb-20 space-y-24">

    <!-- Advantages Grid -->
    <section>
        <div class="flex items-center gap-4 mb-8">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#4fdbc8] text-xl">award_star</span>
                <h2 class="text-3xl font-bold text-white tracking-tight">个人优势</h2>
            </div>
            <div class="h-[1px] flex-grow bg-gradient-to-r from-slate-800 to-transparent"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            @foreach (var adv in PortfolioDataStore.Advantages)
            {
                <div class="glass-card p-6 rounded-xl relative overflow-hidden group cursor-pointer transition-all">
                    <span class="font-mono text-[#4fdbc8] text-3xl font-extrabold opacity-40 block mb-4">
                        @adv.Num
                    </span>
                    <h3 class="text-lg font-bold text-white mb-2">
                        @adv.Title
                    </h3>
                    <p class="text-[#c6c6cd] text-sm leading-relaxed">
                        @adv.Desc
                    </p>
                    <div class="absolute bottom-0 left-0 h-[2px] bg-gradient-to-r from-[#3b82f6] to-[#4fdbc8] w-0 group-hover:w-full transition-all duration-300"></div>
                </div>
            }
        </div>
    </section>

    <!-- Tech Stack Diagnostic Console -->
    <section id="skills">
        <div class="flex items-center gap-4 mb-8">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#4fdbc8] text-xl">terminal</span>
                <h2 class="text-3xl font-bold text-white tracking-tight">技术栈</h2>
            </div>
            <div class="h-[1px] flex-grow bg-gradient-to-r from-slate-800 to-transparent"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Grid Categories -->
            <div class="lg:col-span-7 space-y-6">
                @foreach (var cat in PortfolioDataStore.SkillCategories)
                {
                    <div class="space-y-3">
                        <h4 class="text-xs font-bold uppercase tracking-wider text-[#adc6ff]">
                            @cat.Title
                        </h4>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var tag in cat.Tags)
                            {
                                var isSelected = selectedTag == tag.Name;
                                <button @onclick="() => SelectTag(tag.Name)"
                                    class="skill-tag px-3.5 py-1.5 text-xs rounded transition-all cursor-pointer @(tag.IsCore ? "core-mastery" : "text-slate-400") @(isSelected ? "bg-blue-900/30 border-[#3b82f6] text-white" : "hover:bg-slate-800 hover:text-white")">
                                    @tag.Name
                                    @if (tag.IsCore)
                                    {
                                        <span class="ml-1 text-[9px] bg-[#4fdbc8]/15 text-[#4fdbc8] px-1 rounded">Core</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Terminal output diagnostic console -->
            <div class="lg:col-span-5">
                <div class="glass-card rounded-xl p-6 bg-[#010f1f]/90 border border-slate-700/60 font-mono h-full flex flex-col justify-between">
                    <div>
                        <div class="flex items-center justify-between border-b border-slate-800 pb-3 mb-4">
                            <div class="flex items-center gap-2">
                                <span class="w-3 w-3 h-3 rounded-full bg-red-400"></span>
                                <span class="w-3 w-3 h-3 rounded-full bg-yellow-400"></span>
                                <span class="w-3 w-3 h-3 rounded-full bg-green-400"></span>
                                <span class="text-xs text-slate-400 ml-1">diagnostic_analyzer.sh</span>
                            </div>
                            <span class="text-[10px] bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded">dotnet8</span>
                        </div>

                        <div class="space-y-4">
                            <div class="flex justify-between text-xs">
                                <span class="text-slate-500">SELECTED TARGET:</span>
                                <span class="text-[#4fdbc8] font-bold">@selectedTag</span>
                            </div>
                            <div class="flex justify-between text-xs">
                                <span class="text-slate-500">PARSER STATUS:</span>
                                <span class="text-[10px] bg-[#4fdbc8]/10 text-[#4fdbc8] px-2 py-0.5 rounded border border-[#4fdbc8]/20 animate-pulse">
                                    @currentDiagnostic.Status
                                </span>
                            </div>
                            <p class="text-xs text-slate-400 leading-relaxed border-t border-slate-800/80 pt-4">
                                <span class="text-[#3b82f6]">&gt; </span>@currentDiagnostic.Desc
                            </p>
                        </div>
                    </div>

                    <div class="mt-8 pt-4 border-t border-slate-800/60 space-y-2">
                        <div class="flex justify-between text-[11px]">
                            <span class="text-slate-500">CAPABILITY RATING:</span>
                            <span class="text-[#adc6ff]">@currentDiagnostic.Stat</span>
                        </div>
                        <div class="w-full bg-slate-900 h-2 rounded overflow-hidden">
                            <div class="bg-gradient-to-r from-[#3b82f6] to-[#4fdbc8] h-full transition-all" style="width: 94%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Experience Timelines -->
    <section id="experience">
        <div class="flex items-center gap-4 mb-10">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#4fdbc8] text-xl">work</span>
                <h2 class="text-3xl font-bold text-white tracking-tight">工作经历</h2>
            </div>
            <div class="h-[1px] flex-grow bg-gradient-to-r from-slate-800 to-transparent"></div>
        </div>

        <div class="relative pl-8 border-l-2 border-slate-800 space-y-12">
            @foreach (var work in PortfolioDataStore.WorkHistories)
            {
                var workId = work.Id;
                var isSelected = activeExp == workId;
                <div @onclick="() => SetActiveExp(workId)" class="relative cursor-pointer group">
                    <div class="absolute -left-[41px] top-1.5 w-5 h-5 rounded-full border-4 border-[#051424] transition-all @(work.IsCurrent ? "bg-[#4fdbc8]" : "bg-slate-700")"></div>
                    
                    <div class="glass-card p-6 rounded-xl transition-all @(isSelected ? "border-[#3b82f6] bg-slate-800/30" : "")">
                        <div class="flex flex-col md:flex-row justify-between md:items-center gap-2 mb-4">
                          <div>
                            <h3 class="text-xl font-bold text-white">@work.Company</h3>
                            <p class="text-[#4fdbc8] font-mono text-xs font-bold">@work.Role</p>
                          </div>
                          <span class="text-slate-400 font-mono text-xs bg-slate-900 border border-slate-800 px-3 py-1 rounded">
                              @work.Period
                          </span>
                        </div>
                        
                        <p class="text-slate-300 text-sm leading-relaxed mb-6">@work.Desc</p>

                        <div class="space-y-3 mt-4 border-t border-slate-800/50 pt-4">
                            <h4 class="text-xs font-mono font-bold text-[#adc6ff] uppercase tracking-wider flex items-center gap-1">
                                Achievements
                            </h4>
                            <ul class="space-y-2">
                                @foreach (var ach in PortfolioDataStore.ExperienceAchievements[workId])
                                {
                                    <li class="flex items-start gap-2 text-xs text-slate-400">
                                        <span class="text-[#4fdbc8]">•</span>
                                        <span>@ach</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Projects Grid Slider -->
    <section id="projects">
        <div class="flex items-center gap-4 mb-10">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#4fdbc8] text-xl">database</span>
                <h2 class="text-3xl font-bold text-white tracking-tight">项目经历</h2>
            </div>
            <div class="h-[1px] flex-grow bg-gradient-to-r from-slate-800 to-transparent"></div>
        </div>

        <div class="space-y-12">
            <!-- Feature Project PMIS -->
            <div class="glass-card p-8 rounded-xl bg-gradient-to-r from-[#0f172a]/70 to-[#051424] relative" style="overflow: visible;">
                <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-6">
                    <div>
                        <span class="px-2 bg-slate-700 text-[#adc6ff] text-[10px] font-mono rounded">CORE DESIGN</span>
                        <h3 class="text-2xl font-bold text-white mt-2">PMIS 研发项目管理平台</h3>
                    </div>
                </div>

                <p class="text-[#c6c6cd] text-sm leading-relaxed mb-6">
                    该平台架构完全契合 IPD 系统级质量流转体系，深度服务研发团队。内嵌全生命周期关卡及流式审查机制。
                </p>

                <!-- Interactive tabs -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6" style="position: relative; z-index: 20;">
                    @foreach (var tab in new[] { "flow", "review", "collab", "metrics" })
                    {
                        var isS = selectedPmisTab == tab;
                        var tabLabel = tab switch {
                            "flow" => "流程管理",
                            "review" => "技术评审",
                            "collab" => "协作引擎",
                            "metrics" => "效能分析",
                            _ => tab
                        };
                        <button type="button"
                                @onclick="@(() => SelectPmisTab(tab))"
                                @onclick:stopPropagation="true"
                                style="pointer-events: auto; position: relative; z-index: 30;"
                                class="p-4 rounded-lg border text-left cursor-pointer transition-all @(isS ? "bg-[#1c2b3c] border-[#3b82f6]" : "bg-slate-900/40 border-slate-800 hover:bg-slate-800/60 hover:border-slate-700")">
                            <span class="text-xs uppercase font-mono tracking-wider font-bold text-[#4fdbc8] pointer-events-none">
                                @tabLabel
                            </span>
                        </button>
                    }
                </div>

                <div class="bg-[#010f1f]/80 p-4 rounded border border-slate-800 font-mono text-xs">
                    <span class="text-[#3b82f6]">&gt;&gt; </span> @pmisFeedback
                </div>
            </div>

            <!-- Smart Canteen SaaS -->
            <div class="glass-card p-8 rounded-xl border-t-4 border-t-[#4fdbc8] bg-gradient-to-b from-[#122131]/30 to-[#051424]">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <div class="lg:col-span-7 space-y-6">
                        <h3 class="text-2xl font-bold text-white">智慧食堂 SaaS 平台</h3>
                        <p class="text-slate-300 text-sm leading-relaxed">
                            服务企业园区、医院及学校食堂场景，
                            负责消费结算、充值管理、
                            RFID识别及设备通信功能开发。
                        </p>

                        <!-- Live range component -->
                        <div class="p-4 bg-slate-950/60 rounded border border-slate-900 font-mono text-xs space-y-3">
                            <div class="flex justify-between">
                                <span>POS LATENCY THRESHOLD:</span>
                                <span class="text-[#4fdbc8]">@latencySlider ms</span>
                            </div>
                            <input type="range" min="10" max="100" @bind="latencySlider" @bind:event="oninput"
                                class="w-full" />
                            <div class="flex justify-between text-[10px] text-slate-500">
                                <span>@(latencySlider > 60 ? "⚠️ DETECTOR TIMEOUT POTENTIAL" : "🟢 STABLE")</span>
                            </div>
                        </div>
                    </div>

                    <div class="lg:col-span-5 bg-slate-950/40 p-6 rounded-xl flex flex-col justify-between border border-slate-800">
                        <div class="text-center py-4 bg-[#010f1f] rounded border border-slate-900">
                            <p class="text-mono text-[10px] text-slate-500">设备在线数</p>
                            <p class="text-3xl font-bold text-[#4fdbc8] mt-2">@canteenActiveCount+</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Compact Projects Grid -->
            <div class="mt-16">
                <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[#4fdbc8] text-lg">apps</span>
                    其他项目经历
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    @foreach (var project in PortfolioDataStore.CompactProjects)
                    {
                        <div class="glass-card p-6 rounded-xl border-l-4 border-l-[#4fdbc8] group cursor-pointer">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex-grow">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="px-2 py-0.5 bg-[#3b82f6]/10 border border-[#3b82f6]/30 text-[#3b82f6] text-[10px] font-mono rounded">
                                            @project.Type
                                        </span>
                                        <span class="text-[10px] font-mono text-slate-500">@project.Year</span>
                                    </div>
                                    <h4 class="text-lg font-bold text-white group-hover:text-[#4fdbc8] transition-colors">
                                        @project.Title
                                    </h4>
                                </div>
                            </div>

                            <p class="text-sm text-slate-300 leading-relaxed mb-4">
                                @project.Desc
                            </p>

                            <div class="flex flex-wrap gap-2 pt-3 border-t border-slate-800/50">
                                @foreach (var skill in project.Skills)
                                {
                                    <span class="px-2 py-1 bg-slate-900/60 border border-slate-800 text-[#adc6ff] text-[10px] font-mono rounded">
                                        @skill
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Interactive Contact Form -->
    <section id="contact">
        <div class="flex items-center gap-4 mb-10">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#4fdbc8] text-xl">mail</span>
                <h2 class="text-3xl font-bold text-white tracking-tight">联系合作</h2>
            </div>
            <div class="h-[1px] flex-grow bg-gradient-to-r from-slate-800 to-transparent"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <div class="lg:col-span-7 glass-card p-8 rounded-xl bg-gradient-to-b from-[#122131]/20 to-[#051424]">
                <h3 class="text-xl font-bold mb-4">发送 System Request 握手包</h3>
                
                <EditForm Model="@contactForm" OnValidSubmit="HandleContactSubmit" Enhance="false" class="space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="space-y-1">
                            <label class="text-[10px] font-mono text-slate-500 uppercase">姓名 *</label>
                            <InputText @bind-Value="contactForm.Name" class="w-full bg-[#051424] border border-slate-800 rounded p-2.5 text-xs text-white" />
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-mono text-slate-500 uppercase">邮件 *</label>
                            <InputText @bind-Value="contactForm.Email" class="w-full bg-[#051424] border border-slate-800 rounded p-2.5 text-xs text-white" />
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-mono text-slate-500 uppercase">内容 *</label>
                        <InputTextArea @bind-Value="contactForm.Message" rows="4" class="w-full bg-[#051424] border border-slate-800 rounded p-2.5 text-xs text-white resize-none" />
                    </div>

                    @if (showSuccessMsg)
                    {
                        <div class="p-3 bg-[#4fdbc8]/15 border border-[#4fdbc8]/30 rounded text-xs text-[#4fdbc8] font-mono animate-pulse">
                            ✓ SUCCESS_200: SignalR 实时握手包已传输 - 所有连接客户端已收到通知
                        </div>
                    }

                    @if (hubConnection?.State != HubConnectionState.Connected)
                    {
                        <div class="p-3 bg-yellow-500/15 border border-yellow-500/30 rounded text-xs text-yellow-400 font-mono">
                            ⚠️ SignalR 未连接 - 实时通信功能不可用
                        </div>
                    }

                    <button type="submit"
                        class="w-full bg-[#bec6e0] text-[#283044] hover:bg-white font-mono font-bold text-xs uppercase tracking-widest py-3 rounded cursor-pointer">
                        发送消息
                    </button>
                </EditForm>
            </div>

            <!-- Debug live tracing log -->
            <div class="lg:col-span-5 glass-card p-6 rounded-xl flex flex-col justify-between min-h-[220px]">
                <div class="flex items-center justify-between border-b border-slate-800 pb-3 mb-2 font-mono">
                    <span class="text-xs text-slate-300">SignalR消息</span>
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-ping"></span>
                </div>
                <div class="font-mono text-[10px] text-slate-400 space-y-1.5 flex-grow">
                    @if (traceLogs.Count == 0)
                    {
                        <p class="text-slate-600 italic">等待交互事件...</p>
                    }
                    @foreach (var log in traceLogs)
                    {
                        <p><span class="text-[#3b82f6]">&gt;&gt;</span> @log</p>
                    }
                </div>
            </div>
        </div>
    </section>

</main>

