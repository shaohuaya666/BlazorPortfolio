@code {
    private HubConnection? hubConnection;
    private string selectedTag = ".NET 6/8";
    private string activeExp = "work-1";
    private string selectedPmisTab = "flow";
    private string pmisFeedback = "项目立项流程配置完成，当前流程运行正常。";

    private int latencySlider = 60;
    private int canteenActiveCount = 328;

    private bool resumeModalOpen = false;
    private bool showSuccessMsg = false;
    private int telemetryHz = 60;

    private Timer? hzTimer;
    private Timer? activeCounterTimer;

    private List<string> traceLogs = new();

    private ContactForm contactForm = new();

    private (string Desc, string Stat, string Status) currentDiagnostic =>
        PortfolioDataStore.SkillDiagnostics.TryGetValue(selectedTag, out var diag)
            ? diag
            : ("熟练整合该技术栈，并支持快速构建其企业级交付模块。", "Mastery Level • Dynamic Profile", "MONITORED");

    protected override async Task OnInitializedAsync()
    {
        // 初始化 SignalR 连接
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/portfolioHub"))
            .WithAutomaticReconnect()
            .Build();

        // 注册接收联系日志的处理器
        hubConnection.On<string>("ReceiveContactLog", (log) =>
        {
            traceLogs.Add(log);
            if (traceLogs.Count > 10)
            {
                traceLogs.RemoveAt(0);
            }
            InvokeAsync(StateHasChanged);
        });

        // 注册接收系统日志的处理器
        hubConnection.On<string>("ReceiveSystemLog", (log) =>
        {
            traceLogs.Add(log);
            if (traceLogs.Count > 10)
            {
                traceLogs.RemoveAt(0);
            }
            InvokeAsync(StateHasChanged);
        });

        // 注册接收联系提交成功消息的处理器
        hubConnection.On<string>("ContactSubmitSuccess", (message) =>
        {
            showSuccessMsg = true;
            traceLogs.Add($"[{DateTime.Now:HH:mm:ss}] SUCCESS: {message}");
            if (traceLogs.Count > 10)
            {
                traceLogs.RemoveAt(0);
            }
            InvokeAsync(StateHasChanged);

            // 3秒后隐藏成功消息
            Task.Delay(3000).ContinueWith(_ =>
            {
                showSuccessMsg = false;
                InvokeAsync(StateHasChanged);
            });
        });

        // 启动 SignalR 连接
        try
        {
            await hubConnection.StartAsync();
            AddLog("SignalR 连接已建立 - 实时通信已激活");
        }
        catch (Exception ex)
        {
            AddLog($"SignalR 连接失败: {ex.Message}");
        }

        // Start live simulation updates
        hzTimer = new Timer(_ =>
        {
            var r = new Random();
            telemetryHz = 60 + r.Next(-3, 4);
            InvokeAsync(StateHasChanged);
        }, null, 1500, 1500);

        activeCounterTimer = new Timer(_ =>
        {
            if (canteenActiveCount < 2380)
            {
                var r = new Random();
                canteenActiveCount += r.Next(10, 31);
                InvokeAsync(StateHasChanged);
            }
        }, null, 200, 200);

        AddLog("个人简历系统初始化完成。");
    }

    private void SelectTag(string tag)
    {
        selectedTag = tag;
        AddLog($"DIAGNOSTICS: Target changed to \"{tag}\"");

        // 通过 SignalR 广播系统日志
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            _ = hubConnection.SendAsync("BroadcastSystemLog", $"技术栈切换至: {tag}");
        }
    }

    private void SetActiveExp(string id)
    {
        activeExp = id;
        AddLog($"TIMELINE: Explored detailed records for cluster \"{id}\"");

        // 通过 SignalR 广播系统日志
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            _ = hubConnection.SendAsync("BroadcastSystemLog", $"查看工作经历: {id}");
        }
    }

    private void SelectPmisTab(string tab)
    {
        Console.WriteLine($"[DEBUG] SelectPmisTab called with: {tab}"); // 调试输出
        selectedPmisTab = tab;

        pmisFeedback = tab switch
        {
            "flow" => "项目流程配置与审批节点管理。",
            "review" => "技术评审记录及评审意见跟踪。",
            "collab" => "项目成员协同及任务管理。",
            "metrics" => "项目绩效统计及研发数据分析。",
            _ => "PMIS ACTIVE"
        };

        AddLog($"PMIS模块切换: {tab}");

        // 通过 SignalR 广播系统日志
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            _ = hubConnection.SendAsync("BroadcastSystemLog", $"PMIS 模块切换: {tab}");
        }
    }

    private void ToggleResumeModal()
    {
        resumeModalOpen = !resumeModalOpen;
        AddLog($"MODAL_SNAPSHOT: Requested portable Snap CV binary. Toggle state: {resumeModalOpen}");
    }

    private async Task HandleContactSubmit()
    {
        if (string.IsNullOrWhiteSpace(contactForm.Name) || string.IsNullOrWhiteSpace(contactForm.Email))
            return;

        // 通过 SignalR 发送消息到服务器
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            try
            {
                await hubConnection.SendAsync("SendContactMessage", contactForm.Name, contactForm.Email, contactForm.Message);
                AddLog($"📤 通过 SignalR 发送握手包: {contactForm.Name}");
                contactForm = new();
            }
            catch (Exception ex)
            {
                AddLog($"❌ SignalR 发送失败: {ex.Message}");
            }
        }
        else
        {
            AddLog("⚠️ SignalR 未连接，无法发送消息");
        }
    }

    private void AddLog(string msg)
    {
        traceLogs.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");
        if (traceLogs.Count > 10)
        {
            traceLogs.RemoveAt(0);
        }
    }

    public async ValueTask DisposeAsync()
    {
        hzTimer?.Dispose();
        activeCounterTimer?.Dispose();

        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    public class ContactForm
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }
}
